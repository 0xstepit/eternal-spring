---
import { getMonthShort, getDay } from "../scripts/dates";

interface Props {
  url: string;
  title: string;
  date: Date;
  summary: string;
  tags: string[];
}

const { url, title, date } = Astro.props;

const month = getMonthShort(date);
const day = getDay(date);
---

<li class="post-header-oneline">
  <time class="post-date italic smaller">{`${month} ${day}`}</time>
  <a href={url} class="post-link">{title}</a>
</li>
