---
import type { SocialLink } from "@/types.ts";

interface Props {
  links: SocialLink[];
}

const { links } = Astro.props;
---

<nav class="footer-links" aria-label="Social links">
  {
    links.map((link) => {
      return (
        <a
          class="footer-link principal-link"
          href={link.url}
          aria-label={`Visit ${link.platform}`}
        >
          {link.platform}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="1rem"
            height="1rem"
            viewBox="0 0 16 16"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d={link.svg} />
          </svg>
        </a>
      );
    })
  }
</nav>
